<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="#52FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#80FFFFFF" />
            <padding
                android:left="14dp"
                android:top="12dp"
                android:right="14dp"
                android:bottom="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="0"
                android:startColor="#F9F5FF"
                android:endColor="#ECE4FF" />
            <stroke
                android:width="1dp"
                android:color="#CFC2FF" />
            <padding
                android:left="14dp"
                android:top="12dp"
                android:right="14dp"
                android:bottom="12dp" />
        </shape>
    </item>
</selector>
